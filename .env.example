
# ── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Cloudflare R2 Storage (Private PDF Bucket) ────────────────────────────────
# Create an R2 API Token in: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"

# លេខ Account ID នេះគឺទាញចេញពី Endpoint URL របស់អ្នក
# Find in: Cloudflare Dashboard → R2 → Overview (right sidebar)
R2_ACCOUNT_ID="your_cloudflare_account_id"

# URL សម្រាប់ឲ្យសិស្សទាញយកឯកសារ (ត្រូវមានពាក្យ NEXT_PUBLIC_ ដើម្បីឲ្យ Client Side អាចប្រើបាន)
# Enable public access on your R2 bucket to get this URL
NEXT_PUBLIC_R2_PUBLIC_URL="https://pub-your-hash.r2.dev"

# កុំភ្លេចបំពេញឈ្មោះ Bucket ដែលអ្នកបានបង្កើត (ឧទាហរណ៍៖ elibrary-books)
R2_BUCKET_NAME="your-private-pdf-bucket-name"

# ── Cloudflare R2 (Public Covers Bucket) ─────────────────────────────────────
# Create a separate R2 bucket with public access enabled for book cover images
R2_PUBLIC_BUCKET_NAME="your-public-covers-bucket-name"
NEXT_PUBLIC_R2_COVERS_URL="https://pub-your-covers-hash.r2.dev"

# ── Site URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_ROOT_DOMAIN="your-domain.com"

# ── Vercel Blob (User Avatars) ────────────────────────────────────────────────
# Find in: Vercel Dashboard → Storage → your Blob store → Settings
BLOB_STORE_ID="store_your_blob_store_id"
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_your_store_id_your_token"

# ── Zima Storage (primary file storage) ──────────────────────────────────────
# Self-hosted storage API. All new uploads (books, covers, theses, posts) go
# here; R2 above is only a legacy fallback for old records.
ZIMA_API_URL="https://api.your-storage-domain.com"
ZIMA_API_KEY="your_zima_api_key"

# ── Cloudflare Turnstile CAPTCHA ──────────────────────────────────────────────
# Site key is safe to expose publicly. Get it from: Cloudflare Dashboard → Turnstile
# The secret key is used server-side by /api/contact (and by Supabase Auth via
# the Supabase Dashboard). NEVER commit the real secret.
NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAAAAAA_your_turnstile_site_key"
TURNSTILE_SECRET_KEY="0x4AAAAAAA_your_turnstile_secret_key"

# ── Contact form → Telegram ───────────────────────────────────────────────────
# /api/contact forwards messages to a Telegram chat via a bot.
# Create a bot with @BotFather to get the token; CHAT_ID is the target chat.
TELEGRAM_BOT_TOKEN="123456:your_telegram_bot_token"
TELEGRAM_CHAT_ID="your_telegram_chat_id"

# ── Admin maintenance endpoints ───────────────────────────────────────────────
# Bearer token protecting /api/admin/backfill-embeddings.
# Generate with: openssl rand -hex 32
ADMIN_SECRET_KEY="your_long_random_admin_secret"

# ── ZimaOS self-hosting (see docs/ZIMAOS-DEPLOYMENT.md) ───────────────────────
# Cloudflare Tunnel token for the `cloudflared` compose service. Create in
# Cloudflare Zero Trust → Networks → Tunnels. Treat as a secret.
# TUNNEL_TOKEN="your_cloudflare_tunnel_token"

# ── DDoS / abuse protection (see docs/DDOS-PROTECTION.md) ─────────────────────
# Emergency switches — all default OFF. Set to "true" and redeploy to activate.
# DDOS_MODE=true implies all three switches below it.
# DDOS_MODE="true"
# STRICT_RATE_LIMIT="true"          # divide public rate limits by 3
# DISABLE_EXPENSIVE_SEARCH="true"   # skip AI summary + autocomplete (search still works)
# PDF_DOWNLOAD_LIMIT_STRICT="true"  # clamp PDF read/download limits hard
#
# Optional per-route limit overrides (requests per window; sensible defaults
# apply when unset — see lib/rate-limit-policy.ts):
# RL_SEARCH_PER_MIN=10
# RL_SEARCH_NATIVE_PER_MIN=30
# RL_SUGGESTIONS_PER_MIN=60
# RL_FILE_READ_PER_MIN=30
# RL_DOWNLOAD_PER_MIN=5
# RL_REVIEWS_PER_10MIN=5
# RL_NOTES_PER_MIN=40

# ── Gmail SMTP (for Supabase auth emails) ────────────────────────────────────
# Used by supabase/config.toml [auth.email.smtp] (local dev) and mirrored in
# the Supabase Dashboard → Project Settings → Auth → SMTP Settings (production).
#
# SMTP_USER  — your full Gmail address, e.g. library@gmail.com
# SMTP_PASS  — a 16-char Gmail App Password (NOT your real Gmail password).
#              To generate one:
#                1. Enable 2-Step Verification on the Google account.
#                2. Go to https://myaccount.google.com/apppasswords
#                3. Create an app → copy the 16-char password (no spaces).
#              Gmail free tier allows ~500 emails/day.
#              To switch providers later (Resend, SendGrid, SES), change only
#              host/port/user/pass in config.toml — no other code changes needed.
SMTP_USER="your-gmail-address@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"

# ── AI Assistant (server-side only — NEVER prefix with NEXT_PUBLIC_) ─────────
# Get your key from https://aistudio.google.com/apikey
GEMINI_API_KEY="your_gemini_api_key"

# ── Cron Jobs ─────────────────────────────────────────────────────────────────
# Shared secret protecting /api/cron/* routes (e.g. /api/cron/cleanup, which
# purges stale rate_limit rows daily). Generate with: openssl rand -hex 32
# Vercel Cron sends it automatically as "Authorization: Bearer <CRON_SECRET>";
# external cron services must send the same header.
CRON_SECRET="your_long_random_cron_secret"

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate a key pair with: npx web-push generate-vapid-keys
# Used for push notifications (new-publication alerts, admin broadcasts).
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your_vapid_public_key"
VAPID_PRIVATE_KEY="your_vapid_private_key"
VAPID_MAILTO="mailto:library@your-domain.com"
