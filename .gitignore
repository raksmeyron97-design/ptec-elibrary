# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma
/public/pdf/

# design-sync — build output and generated cache (NOT the config, previews, or converter scripts)
/ds-bundle/
/ds-entry.ts
/.design-sync/.cache/
/.design-sync/compiled-globals.css
/.ds-sync/node_modules/

# Lighthouse / PSI output (scripts write here; large, machine-generated)
/reports/

# Playwright output — regenerated on every `npx playwright test` run.
# (7 of these were committed by accident; they are artifacts, not source.)
playwright-report/
test-results/
